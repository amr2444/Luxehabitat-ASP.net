@model RealEstate.Web.ViewModels.Shared.NotificationPanelViewModel

<div class="notification-panel">
    <button type="button" class="notification-trigger" aria-expanded="false">
        <span class="notification-trigger__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 18H5a1 1 0 0 1-.8-1.6l1.6-2.1V10a6 6 0 1 1 12 0v4.3l1.6 2.1A1 1 0 0 1 18.6 18H15Z" />
                <path d="M9.5 20a2.5 2.5 0 0 0 5 0" />
            </svg>
            @if (Model.UnreadCount > 0)
            {
                <span class="notification-trigger__dot"></span>
            }
        </span>
        <span class="notification-trigger__count">@Model.UnreadCount</span>
    </button>

    <div class="notification-dropdown">
        <div class="notification-header">
            <div>
                <div class="notification-header__label">Notifications</div>
                <div class="notification-header__title">Centre de veille</div>
            </div>
            <div class="d-flex gap-2 align-items-center">
                @if (Model.UnreadCount > 0)
                {
                    <form asp-controller="Notification" asp-action="MarkAllAsRead" method="post" class="notification-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-dark btn-sm">Tout lire</button>
                    </form>
                }
                <button type="button" class="btn btn-outline-dark btn-sm notification-refresh">Refresh</button>
            </div>
        </div>

        @if (Model.Items.Any())
        {
            <div class="notification-list">
                @foreach (var item in Model.Items)
                {
                    <div class="notification-item">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="notification-item__title">@item.Title</div>
                                <div class="notification-item__message">@item.Message</div>
                            </div>
                            @if (!item.IsRead)
                            {
                                <form asp-controller="Notification" asp-action="MarkAsRead" method="post" class="notification-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="notificationId" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-dark btn-sm">Lire</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M7 10h10" />
                        <path d="M7 14h6" />
                        <path d="M5 5h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H8l-5 3V7a2 2 0 0 1 2-2Z" />
                    </svg>
                </div>
                <div class="empty-state__title">Silence editorial</div>
                <p class="empty-state__copy mb-0">Aucune notification recente. Les nouvelles interactions apparaitront ici.</p>
            </div>
        }
    </div>
</div>
