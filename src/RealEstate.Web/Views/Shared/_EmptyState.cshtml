@model EmptyStateViewModel
<div class="empty-state">
    <h3 class="h5">@Model.Title</h3>
    <p class="mb-3">@Model.Message</p>
    @if (!string.IsNullOrWhiteSpace(Model.ActionText) && !string.IsNullOrWhiteSpace(Model.ActionUrl))
    {
        <a href="@Model.ActionUrl" class="btn btn-dark">@Model.ActionText</a>
    }
</div>
