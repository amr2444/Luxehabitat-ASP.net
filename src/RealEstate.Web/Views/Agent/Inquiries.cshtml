@model IReadOnlyCollection<AgentInquiryListItemViewModel>
@{
    ViewData["Title"] = "Demandes";
}

<h1 class="section-title mb-4">Demandes recues</h1>

@if (Model.Any())
{
    <div class="table-shell">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Bien</th>
                    <th>Locataire</th>
                    <th>Sujet</th>
                    <th>Message</th>
                    <th>Statut</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var tone = item.Status switch
                    {
                        RealEstate.Domain.Enums.InquiryStatus.New => "draft",
                        RealEstate.Domain.Enums.InquiryStatus.InProgress => "published",
                        _ => "archived"
                    };

                    <tr>
                        <td>@item.PropertyTitle</td>
                        <td>@item.TenantDisplayName</td>
                        <td>@item.Subject</td>
                        <td class="text-muted">@item.Message</td>
                        <td>
                            <partial name="_StatusBadge" model='new RealEstate.Web.ViewModels.Shared.StatusBadgeViewModel { Text = item.Status.ToString(), Tone = tone }' />
                        </td>
                        <td>@item.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                        <td class="table-actions">
                            <form asp-action="UpdateInquiryStatus" method="post" class="d-flex gap-2 align-items-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="InquiryId" value="@item.Id" />
                                <select name="Status" class="form-select form-select-sm">
                                    @foreach (var status in Enum.GetValues<RealEstate.Domain.Enums.InquiryStatus>())
                                    {
                                        if (status == item.Status)
                                        {
                                            <option value="@status" selected>@status</option>
                                        }
                                        else
                                        {
                                            <option value="@status">@status</option>
                                        }
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-dark">Mettre a jour</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <partial name="_EmptyState" model='new RealEstate.Web.ViewModels.Shared.EmptyStateViewModel { Title = "Aucune demande", Message = "Les demandes recues apparaitront ici." }' />
}
