@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1 class="section-title mb-4">Admin Dashboard</h1>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-2"><partial name="_StatsCard" model='new RealEstate.Web.ViewModels.Shared.StatsCardViewModel { Value = Model.UsersCount.ToString(), Label = "Utilisateurs" }' /></div>
    <div class="col-md-6 col-xl-2"><partial name="_StatsCard" model='new RealEstate.Web.ViewModels.Shared.StatsCardViewModel { Value = Model.AgentsCount.ToString(), Label = "Agents" }' /></div>
    <div class="col-md-6 col-xl-2"><partial name="_StatsCard" model='new RealEstate.Web.ViewModels.Shared.StatsCardViewModel { Value = Model.ActiveAgentsCount.ToString(), Label = "Agents actifs" }' /></div>
    <div class="col-md-6 col-xl-2"><partial name="_StatsCard" model='new RealEstate.Web.ViewModels.Shared.StatsCardViewModel { Value = Model.TenantCount.ToString(), Label = "Locataires" }' /></div>
    <div class="col-md-6 col-xl-2"><partial name="_StatsCard" model='new RealEstate.Web.ViewModels.Shared.StatsCardViewModel { Value = Model.PropertiesCount.ToString(), Label = "Annonces" }' /></div>
    <div class="col-md-6 col-xl-2"><partial name="_StatsCard" model='new RealEstate.Web.ViewModels.Shared.StatsCardViewModel { Value = Model.RentalsCount.ToString(), Label = "Locations" }' /></div>
</div>

<div class="admin-card">
    <h2 class="h5 mb-3">Agents en attente</h2>
    @if (Model.PendingAgents.Any())
    {
        <div class="table-shell">
            <table class="table align-middle">
                <thead>
                    <tr><th>Agence</th><th>Licence</th><th>Biens</th><th>Avis</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.PendingAgents)
                    {
                        <tr>
                            <td>@item.AgencyName</td>
                            <td>@item.LicenseNumber</td>
                            <td>@item.PropertiesCount</td>
                            <td>@item.ReviewsCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <partial name="_EmptyState" model='new RealEstate.Web.ViewModels.Shared.EmptyStateViewModel { Title = "Aucun agent en attente", Message = "La moderation agent est a jour." }' />
    }
</div>
