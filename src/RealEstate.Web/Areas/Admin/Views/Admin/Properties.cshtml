@model IReadOnlyCollection<RealEstate.Web.ViewModels.Dashboard.AdminPropertyListItemViewModel>
@{
    ViewData["Title"] = "Annonces";
}

<h1 class="section-title mb-4">Annonces</h1>

<div class="table-shell">
    <table class="table align-middle">
        <thead>
            <tr><th>Titre</th><th>Agent</th><th>Ville</th><th>Statut</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.AgentName</td>
                    <td>@item.City</td>
                    <td>
                        <partial name="_StatusBadge" model='new RealEstate.Web.ViewModels.Shared.StatusBadgeViewModel { Text = item.Status, Tone = item.IsDeleted ? "archived" : item.Status == "Published" ? "published" : "draft" }' />
                    </td>
                    <td class="table-actions">
                        <div class="d-flex gap-2">
                            <form asp-action="SuspendProperty" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="propertyId" value="@item.PropertyId" />
                                <button type="submit" class="btn btn-sm btn-outline-dark">Suspendre</button>
                            </form>
                            <form asp-action="DeleteProperty" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="propertyId" value="@item.PropertyId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
