@model IReadOnlyCollection<RealEstate.Web.ViewModels.Dashboard.AdminPropertyListItemViewModel>
@{
    ViewData["Title"] = "Annonces";
}

<section class="admin-hub">
    <div class="admin-hub__hero admin-hub__hero--compact">
        <div>
            <span class="admin-hub__eyebrow">Moderation catalogue</span>
            <h1 class="section-title">Annonces</h1>
            <p class="admin-hub__lead">
                Controlez la qualite du portefeuille public, suspendez les annonces sensibles et supprimez les
                contenus qui ne doivent plus etre visibles sur la plateforme.
            </p>
        </div>
    </div>

    <section class="admin-panel">
        @if (Model.Any())
        {
            <div class="table-shell admin-table-shell">
                <table class="table align-middle admin-table">
                    <thead>
                        <tr><th>Titre</th><th>Agent</th><th>Ville</th><th>Statut</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="admin-table__primary">@item.Title</div>
                                    <div class="admin-table__secondary">Annonce immobiliere</div>
                                </td>
                                <td class="admin-table__muted">@item.AgentName</td>
                                <td class="admin-table__muted">@item.City</td>
                                <td>
                                    <partial name="_StatusBadge" model='new RealEstate.Web.ViewModels.Shared.StatusBadgeViewModel { Text = item.Status, Tone = item.IsDeleted ? "archived" : item.Status == "Published" ? "published" : "draft" }' />
                                </td>
                                <td class="table-actions">
                                    <div class="admin-action-row">
                                        <form asp-action="SuspendProperty" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="propertyId" value="@item.PropertyId" />
                                            <button type="submit" class="btn btn-sm btn-outline-dark">Suspendre</button>
                                        </form>
                                        <form asp-action="DeleteProperty" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="propertyId" value="@item.PropertyId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <partial name="_EmptyState" model='new RealEstate.Web.ViewModels.Shared.EmptyStateViewModel { Title = "Aucune annonce", Message = "Les annonces en portefeuille apparaitront ici." }' />
        }
    </section>
</section>
